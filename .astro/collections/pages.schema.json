{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "excerpt": {
      "type": "string"
    },
    "published": {
      "default": true,
      "type": "boolean"
    },
    "content_blocks": {
      "default": [],
      "type": "array",
      "items": {}
    },
    "seo": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "canonical_url": {
          "type": "string"
        },
        "featured_image": {
          "type": "string"
        },
        "open_graph_type": {
          "default": "website",
          "type": "string",
          "enum": [
            "website",
            "article",
            "product"
          ]
        },
        "no_index": {
          "default": false,
          "type": "boolean"
        }
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title"
  ]
}