          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "image": {
          "type": "string"
        },
        "image_alt": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "seo": {
          "type": "object",
          "properties": {
            "page_description": {
              "type": "string"
            },
            "canonical_url": {
              "type": "string"
            },
            "featured_image": {
              "type": "string"
            },
            "open_graph_type": {
              "type": "string",
