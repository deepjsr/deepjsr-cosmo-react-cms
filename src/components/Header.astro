---
import site from '../data/site.json';
import navigation from '../data/navigation.json';
const path = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-primary/10 bg-bg/80 backdrop-blur">
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-5 py-4 sm:px-8">
    <a href="/" class="font-display text-2xl tracking-wide text-ink">
      {site.name}
    </a>
    <nav class="hidden items-center gap-8 md:flex">
      {
        navigation.items.map((item: any) => (
          <a
            href={item.url}
            class:list={[
              'text-sm transition hover:text-primary',
              path === item.url ? 'text-primary font-medium' : 'text-ink/80',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <a
      href="/contact"
      class="rounded-full bg-primary px-5 py-2 text-sm font-medium text-primary-foreground transition hover:opacity-90"
    >
      Book a consult
    </a>
  </div>
</header>
