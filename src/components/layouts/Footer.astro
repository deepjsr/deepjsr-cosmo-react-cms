---
import footer from '../../../data/footer.json';
import social from '../../../data/social.json';
import site from '../../../data/site.json';

const year = new Date().getFullYear();
---

<footer class="border-t border-black/5 bg-surface">
  <div class="container-page grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <a href="/" class="text-xl font-semibold">{site.site_title}</a>
      <p class="mt-3 max-w-xs text-sm text-muted">{site.description}</p>
      <div class="mt-4 flex gap-3">
        {
          social.map((s) => (
            <a href={s.url} target="_blank" rel="noopener" class="text-sm font-medium text-muted hover:text-primary">
              {s.platform}
            </a>
          ))
        }
      </div>
    </div>

    {
      footer.columns.map((col) => (
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wide text-ink">{col.title}</h3>
          <ul class="mt-3 space-y-2">
            {col.links.map((link) => (
              <li>
                <a href={link.link} class="text-sm text-muted hover:text-primary">{link.text}</a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <div class="container-page flex flex-col items-center justify-between gap-3 border-t border-black/5 py-6 text-sm text-muted sm:flex-row">
    <p>{footer.copyright.replace('2026', String(year))}</p>
    <p>{footer.bottom_note}</p>
  </div>
</footer>
