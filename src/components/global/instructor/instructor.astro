---
const { name = '', role = '', bio = '', image = 'https://placehold.co/600x600?text=Lumi%C3%A8re', image_alt = '' } = Astro.props;
---

<section class="py-16 sm:py-24">
  <div class="container-page grid items-center gap-12 lg:grid-cols-2">
    <img
      src={image}
      alt={image_alt || name}
      class="w-full max-w-md justify-self-center rounded-[var(--theme-radius)] object-cover shadow-md"
      loading="lazy"
    />
    <div>
      {name && <h2 class="text-3xl font-semibold sm:text-4xl">{name}</h2>}
      {role && <p class="mt-2 text-primary">{role}</p>}
      {bio && <p class="mt-4 text-muted" set:html={bio} />}
    </div>
  </div>
</section>
