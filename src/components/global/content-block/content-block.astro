---
// Generic editable block. Renders a heading and a block of HTML content
// supplied by the editor (set:html keeps inline formatting safe).
const { heading = '', subheading = '', content = '' } = Astro.props;
---
<section class="py-16 sm:py-24">
  <div class="container-page max-w-3xl">
    {heading && <h2 class="text-3xl font-semibold sm:text-4xl">{heading}</h2>}
    {subheading && <p class="mt-4 text-lg text-muted">{subheading}</p>}
    {content && <div class="mt-6 text-muted" set:html={content} />}
    <slot />
  </div>
</section>

