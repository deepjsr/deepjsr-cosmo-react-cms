---
import Button from '../../shared/Button.astro';
import SectionWrapper from '../../shared/SectionWrapper.astro';

const { heading = '', subheading = '', tiers = [] } = Astro.props;
---

<SectionWrapper heading={heading} subheading={subheading}>
  <div class="grid gap-8 lg:grid-cols-3">
    {
      tiers.map((tier: any) => (
        <div
          class={`flex flex-col rounded-[var(--theme-radius)] border p-8 ${
            tier.highlight ? 'border-primary bg-primary-soft shadow-md' : 'border-black/10 bg-surface'
          }`}
        >
          <h3 class="text-xl font-semibold">{tier.name}</h3>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="text-4xl font-semibold">{tier.price}</span>
            {tier.period && <span class="text-muted">{tier.period}</span>}
          </div>
          {tier.description && <p class="mt-3 text-muted">{tier.description}</p>}
          <ul class="mt-6 flex-1 space-y-2">
            {(tier.features || []).map((feat: any) => (
              <li class="flex items-start gap-2 text-sm text-muted">
                <span class="mt-0.5 text-primary">✓</span>
                <span>{feat}</span>
              </li>
            ))}
          </ul>
          {tier.button?.text && (
            <div class="mt-8">
              <Button text={tier.button.text} link={tier.button.link} variant={tier.highlight ? 'primary' : 'secondary'} class="w-full" />
            </div>
          )}
        </div>
      ))
    }
  </div>
</SectionWrapper>
