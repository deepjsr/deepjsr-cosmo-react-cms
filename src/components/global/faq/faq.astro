---
import SectionWrapper from '../../shared/SectionWrapper.astro';

const { heading = '', subheading = '', items = [] } = Astro.props;
---

<SectionWrapper heading={heading} subheading={subheading}>
  <div class="mx-auto max-w-3xl divide-y divide-black/5 rounded-[var(--theme-radius)] border border-black/5 bg-surface">
    {
      items.map((item: any) => (
        <details class="faq-item group p-6" name="faq">
          <summary class="flex items-center justify-between font-semibold">
            <span>{item.question}</span>
            <span class="ml-4 text-primary transition-transform group-open:rotate-45">+</span>
          </summary>
          <p class="mt-3 text-muted" set:html={item.answer} />
        </details>
      ))
    }
  </div>
</SectionWrapper>
