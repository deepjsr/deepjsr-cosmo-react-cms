---
import SectionWrapper from '../../shared/SectionWrapper.astro';

const { heading = '', subheading = '', rows = [] } = Astro.props;
---

<SectionWrapper heading={heading} subheading={subheading}>
  <div class="space-y-16">
    {
      rows.map((row: any, i: number) => (
        <div class="grid items-center gap-10 lg:grid-cols-2">
          <img
            src={row.image || 'https://placehold.co/900x700?text=Lumi%C3%A8re'}
            alt={row.image_alt || row.title || ''}
            class={`w-full rounded-[var(--theme-radius)] object-cover shadow-md ${i % 2 === 1 ? 'lg:order-2' : ''}`}
            loading="lazy"
          />
          <div>
            <h3 class="text-2xl font-semibold">{row.title}</h3>
            {row.text && <p class="mt-4 text-muted">{row.text}</p>}
          </div>
        </div>
      ))
    }
  </div>
</SectionWrapper>
