---
import site from '../data/site.json';
import footer from '../data/footer.json';
import social from '../data/social.json';

const year = new Date().getFullYear();
const copyright = (footer.copyright as string).replace('{year}', String(year));
---

<footer class="border-t border-primary/10 bg-surface/40">
  <div class="mx-auto w-full max-w-6xl px-5 py-14 sm:px-8">
    <div class="grid gap-10 md:grid-cols-4">
      <div>
        <div class="font-display text-2xl text-ink">{site.name}</div>
        <p class="mt-3 max-w-xs text-sm text-muted">{footer.tagline}</p>
        <p class="mt-4 text-sm text-muted">{site.address}</p>
        <p class="mt-1 text-sm text-muted">{site.email}</p>
      </div>
      {
        footer.columns.map((col: any) => (
          <div>
            <div class="font-display text-lg text-ink">{col.title}</div>
            <ul class="mt-4 space-y-2">
              {col.links.map((link: any) => (
                <li>
                  <a href={link.url} class="text-sm text-muted hover:text-primary">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-primary/10 pt-6 sm:flex-row">
      <p class="text-xs text-muted">{copyright}</p>
      <div class="flex gap-4">
        {
          social.items.map((s: any) => (
            <a
              href={s.url}
              class="text-sm text-muted uppercase tracking-wide hover:text-primary"
              rel="noopener"
            >
              {s.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
