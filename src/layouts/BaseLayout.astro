---
import { SEO } from 'astro-seo';
import '../styles/global.css';
import theme from '../data/theme.json';
import site from '../data/site.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  canonical?: string;
}

const {
  title = site.name,
  description = site.description,
  image = 'https://placehold.co/1200x630.png',
  imageAlt = site.name,
  canonical,
} = Astro.props;

const themeVars = [
  `--color-primary:${theme.primary_color}`,
  `--color-primary-foreground:${theme.primary_foreground}`,
  `--color-accent:${theme.accent_color}`,
  `--color-bg:${theme.background_color}`,
  `--color-surface:${theme.surface_color}`,
  `--color-ink:${theme.text_color}`,
  `--color-muted:${theme.muted_color}`,
  `--font-display:${theme.heading_font}`,
  `--font-body:${theme.body_font}`,
].join(';');

const canonicalURL = canonical
  ? new URL(canonical, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
---

<!doctype html>
<html lang={site.language} style={themeVars}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          title,
          type: 'website',
          image: ogImage.href,
        },
        image: { alt: imageAlt },
        optional: {
          description,
        },
      }}
      twitter={{
        card: 'summary_large_image',
        title,
        description,
        image: ogImage.href,
      }}
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
