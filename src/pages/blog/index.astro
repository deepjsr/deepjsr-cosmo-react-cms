---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Routines & Journal — Lumière Skin"
  description="Skincare routines, ingredient deep-dives and rituals from the Lumière Skin beauty lab."
  image="https://placehold.co/1200x630.png"
  imageAlt="Lumière Skin routines and journal"
>
  <section class="py-16 sm:py-24">
    <div class="mx-auto w-full max-w-6xl px-5 sm:px-8">
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-accent"
        >Journal</span
      >
      <h1 class="mt-3 font-display text-4xl text-ink sm:text-5xl">
        Routines & Rituals
      </h1>
      <p class="mt-4 max-w-2xl text-muted">
        Considered advice on ingredients, skin types and the art of a luminous
        routine — written by our estheticians.
      </p>

      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group block overflow-hidden rounded-card bg-bg shadow-sm transition hover:shadow-md"
            >
              <img
                src={post.data.hero_image || 'https://placehold.co/800x800.png'}
                alt={post.data.image_alt || post.data.title}
                class="aspect-square w-full object-cover"
              />
              <div class="p-5">
                <div class="text-xs uppercase tracking-wide text-accent">
                  {post.data.category}
                </div>
                <h2 class="mt-2 font-display text-xl text-ink">
                  {post.data.title}
                </h2>
                <p class="mt-2 line-clamp-3 text-sm leading-relaxed text-muted">
                  {post.data.excerpt}
                </p>
                <div class="mt-4 text-xs text-muted">
                  {post.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
