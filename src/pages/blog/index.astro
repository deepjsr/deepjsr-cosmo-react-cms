---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Layout
  title="Routines & Journal"
  description="Skincare routines, ingredient deep-dives and brand stories from the Lumière Skin team."
>
  <section class="py-16 sm:py-24">
    <div class="container-page">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-semibold sm:text-5xl">Routines & Journal</h1>
        <p class="mt-4 text-lg text-muted">
          Skincare routines, ingredient deep-dives and stories from our team.
        </p>
      </div>

      {
        posts.length === 0 ? (
          <p class="mt-12 text-center text-muted">No posts yet — check back soon.</p>
        ) : (
          <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <a href={`/blog/${post.id}`} class="group block overflow-hidden rounded-[var(--theme-radius)] border border-black/5 bg-surface shadow-sm transition-shadow hover:shadow-md">
                {post.data.image && (
                  <img src={post.data.image} alt={post.data.image_alt || post.data.title} class="aspect-[4/3] w-full object-cover" loading="lazy" />
                )}
                <div class="p-6">
                  <div class="flex flex-wrap gap-2">
                    {(post.data.tags || []).slice(0, 3).map((tag) => (
                      <span class="rounded-full bg-primary-soft px-3 py-1 text-xs font-medium text-primary">{tag}</span>
                    ))}
                  </div>
                  <h2 class="mt-3 text-xl font-semibold group-hover:text-primary">{post.data.title}</h2>
                  {post.data.description && <p class="mt-2 text-sm text-muted">{post.data.description}</p>}
                </div>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Layout>
